#!/bin/zsh
set -euo pipefail

if [ $# -ne 3 ]; then
  echo "Usage: $0 <github-repo> <cask-name> <dmg-file>"
  echo "Example: $0 someone/homebrew-tap appname ./AppName-1.3.5.dmg"
  exit 1
fi

GITHUB_REPO="$1"
CASK_NAME="$2"
DMG_PATH="$3"

if [ ! -f "$DMG_PATH" ]; then
  echo "DMG file not found: $DMG_PATH"
  exit 1
fi

TAP_REPO_URL="git@github.com:${GITHUB_REPO}.git"

FILE_NAME="$(basename "$DMG_PATH")"

VERSION="$(echo "$FILE_NAME" | sed -E 's/^[^-]+-([0-9]+(\.[0-9]+)*).*\.dmg$/\1/')"

if [ -z "$VERSION" ] || [ "$VERSION" = "$FILE_NAME" ]; then
  echo "Failed to extract version from filename: $FILE_NAME"
  echo "Expected something like: PromptFlow-0.3.1.dmg"
  exit 1
fi

SHA256="$(shasum -a 256 "$DMG_PATH" | awk '{print $1}')"

WORK_DIR="$(mktemp -d)"
trap 'rm -rf "$WORK_DIR"' EXIT

echo "Cloning ${GITHUB_REPO}..."
git clone "$TAP_REPO_URL" "$WORK_DIR/homebrew-tap"

cd "$WORK_DIR/homebrew-tap"

CASK_FILE="Casks/${CASK_NAME}.rb"

if [ ! -f "$CASK_FILE" ]; then
  echo "Cask file not found: $CASK_FILE"
  exit 1
fi

echo "Updating $CASK_FILE"
echo "  version: $VERSION"
echo "  sha256 : $SHA256"

ruby -0777 -i -pe "
  gsub(/version \".*?\"/, 'version \"$VERSION\"');
  gsub(/sha256 \".*?\"/, 'sha256 \"$SHA256\"');
" "$CASK_FILE"

echo
echo "Diff:"
git diff -- "$CASK_FILE"

if git diff --quiet -- "$CASK_FILE"; then
  echo "No changes."
  exit 0
fi

git add "$CASK_FILE"
git commit -m "Update ${CASK_NAME} to ${VERSION}"
git push

echo
echo "Running brew audit..."
brew update
brew audit --cask "$CASK_NAME"

echo
echo "Done."
