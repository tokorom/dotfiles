{
  "allowlist": [
    "git *",
    "xcodebuild *",
    "pwd *",
    "ls *",
    "cd *",
    "grep *",
    "cp *",
    "mv *",
    "sed *",
    "chmod *",
    "perl *",
    "npm *",
    "make *"
  ],
  "mcpServers": {
    "xcode": {
      "command": "xcrun",
      "args": ["mcpbridge"],
      "timeout": 300000,
      "trust": true
    }
  }
}
